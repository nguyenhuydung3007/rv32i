// =====================================
// Testbench  Data_RAM
// =====================================

`timescale 1ns/1ps

module tb_Data_RAM;
	reg clk;
	reg [31:0] addr;
	reg [31:0] wr_data;
	reg read_en;
	reg write_en;
	
	wire [31:0] rd_data;
	
	initial begin
		clk = 0;
		forever #10 clk = ~clk;
	end
	
	initial begin
		// Test case 1: Write
		addr = 32'h0000_0023;
		wr_data = 32'h0001_ABCD;
		read_en = 0;
		write_en = 1;
		
		// Test case 2: Write
		addr = 32'h0000_0034;
		wr_data = 32'h0000_1234;
		read_en = 0;
		write_en = 1;
		
		// Test case 3: Read
		addr = 32'h0000_0023;
		read_en = 1;
		write_en = 0;
		
		// Test case 4: Read
		addr = 32'h0000_0034;
		read_en = 1;
		write_en = 0;
		
		// Test case 5: Write 
		addr = 32'h0000_0034;
		wr_data = 32'h0000_4567;
		read_en = 0;
		write_en = 1;
		
		// Test case 6: Read
		addr = 32'h0000_0034;
		read_en = 1;
		write_en = 0;
	end
	
	
endmodule