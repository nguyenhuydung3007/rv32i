// ======================================
// Testbench ALU_Control
// ======================================

`timescale 1ns/1ps

module tb_ALU_Control;
	reg [6:0] opcode;
	reg [2:0] funct3;
	reg [6:0] funct7;
	
	wire [3:0] alu_op;
	
	ALU_Control ALU_Control_uut (
		.opcode (opcode),
		.funct3 (funct3),
		.funct7 (funct7),
		.alu_op (alu_op)
	);
	
endmodule