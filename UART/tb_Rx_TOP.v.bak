`timescale 1ns/1ps

module tb_Rx_TOP;

    parameter CLK_SYS    = 50_000_000;
    parameter BAUD_RATE  = 9600;
    parameter OVERSAMPLE = 16;
    parameter DATA_BITS  = 8;

    // =========================
    // Clock
    // =========================
    reg clk;
    always #10 clk = ~clk; // 50MHz

    // =========================
    // DUT signals
    // =========================
    reg reset;
    reg rx;

    reg fifo_rd_en;
    wire [7:0] fifo_data_out;
    wire fifo_empty;
    wire fifo_full;
    wire rx_irq;

    // =========================
    // Baud tick giả lập
    // =========================
    reg baud_tick;

    // Chu kỳ baud_tick (approx)
    integer tick_cnt;

    // =========================
    // DUT
    // =========================
    Rx_TOP uut (
        .clk            (clk),
        .reset          (reset),
        .rx_serial_in   (rx),

        .fifo_rd_en     (fifo_rd_en),
        .fifo_data_out  (fifo_data_out),
        .fifo_empty     (fifo_empty),
        .fifo_full      (fifo_full),
        .rx_irq         (rx_irq)
    );

    // =========================
    // Force baud_tick
    // =========================
    // Vì Rx_TOP có Baud_Gen bên trong
    // ta override bằng force
    always begin
        #(320) baud_tick = 1;
        #(20)  baud_tick = 0;
    end

    initial begin
        force uut.baud_gen.baud_tick = baud_tick;
    end

    // =========================
    // UART SEND TASK
    // =========================
    task uart_send_byte(input [7:0] data);
        integer i;
        begin
            // START bit
            rx = 0;
            repeat (OVERSAMPLE) @(posedge baud_tick);

            // DATA bits (LSB first)
            for (i = 0; i < 8; i = i + 1) begin
                rx = data[i];
                repeat (OVERSAMPLE) @(posedge baud_tick);
            end

            // STOP bit
            rx = 1;
            repeat (OVERSAMPLE) @(posedge baud_tick);
        end
    endtask

    // =========================
    // TEST
    // =========================
    initial begin
        clk = 0;
        reset = 1;
        rx = 1;
        fifo_rd_en = 0;
        baud_tick = 0;

        #100;
        reset = 0;

        // =====================
        // SEND DATA
        // =====================
        uart_send_byte(8'h55); // 01010101
        uart_send_byte(8'hA3);
        uart_send_byte(8'h7F);

        // chờ FIFO nhận
        #10000;

        // =====================
        // READ FIFO
        // =====================
        repeat (3) begin
            @(posedge clk);
            fifo_rd_en = 1;
            @(posedge clk);
            fifo_rd_en = 0;

            #100;
        end

        #1000;
        $stop;
    end

endmodule